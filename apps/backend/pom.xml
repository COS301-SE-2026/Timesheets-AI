<!--
This file tells Maven ( builds the project, manages dependencies and runs tests)
* who you are (groupId, artifactId, version)
* how to build 
* the dependencies, modules and packages used

Lifecyle  of Maven:
comile -> test -> package -> install 

** For the test ** 
it must end with:
- *Test.java
- *Tests.java
- *TestCase.java
-->

<!--
Needed to be updated: it does not yet support for Spring Boot, PostgreSQL and maybe Security
-->

<project xmlns="https://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
<modelVersion> 4.0.0 </modelVersion>

<!-- the parent will handle and download the versions we need -->
<parent>
    <groupId>org.springframework.boot</groupId> <!-- the organisation that created that parent -->
    <artifactId>spring-boot-starter-parent</artifactId> <!--specifies which parent to inherits from -->
    <version>3.5.0-SNAPSHOT</version> <!-- indicate that we are still in development version -->
    <relativePath/> <!-- forces not search locally for parent POM but to download it -->
</parent>

<groupId>com.timesheetai</groupId> <!-- identifier for the project across all other projects -->
<artifactId>timesheet-ai</artifactId> <!-- name of the project -->
<version> 0.0.1-SNAPSHOT</version> <!-- the project has not been released (project version) -->

<properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding> <!-- ensure the same character encoding for each file -->
    <java.version>17</java.version> <!-- ensure that the code is compiled for Java 17 (for Java 9+)-->
</properties>

<!-- plugins (referred to a) vs plugins management (referred to b)
(a) plugins for the backend folder
these are active plugins used during the build.
Maven will download and run them (plugins) automatically and execute (use) it in the build 

(b) is the default 
Maven will not execute the plugins 
just define the versions and shared configurations used by others. 
-->


<build>
    <plugins>
        <plugin>
            <artifactId>maven-surefire-plugin</artifactId> <!-- runs the unit tests during build -->
            <version>3.1.2</version>
        </plugin>
    </plugins>
</build>
</project>