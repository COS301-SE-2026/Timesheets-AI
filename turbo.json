{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "target/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "coverage": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**", "htmlcov/**", "target/site/jacoco/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
